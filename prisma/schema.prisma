// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BusOperationalStatus {
  ACTIVE
  REPAIR
  STANDBY
}

enum BusServiceStatus {
  NORMAL
  WARNING
  DELAYED
}

enum RouteStatus {
  ON_SCHEDULE
  MINOR_DELAYS
  DELAYED
}

enum BusEventType {
  PASSENGER_IN
  PASSENGER_OUT
  RFID_STOP
}

enum AuditLogStatus {
  SUCCESS
  FAILED
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String?   @default("user")
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  auditLogs     AuditLog[]

  @@map("user")
}

model AuditLog {
  id          String         @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  status      AuditLogStatus @default(SUCCESS)
  actorUserId String?
  actorRole   String?
  ipAddress   String?
  userAgent   String?
  details     Json?
  createdAt   DateTime       @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([actorUserId])
  @@index([status])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Route {
  id           String            @id @default(cuid())
  code         String            @unique
  name         String
  status       RouteStatus       @default(ON_SCHEDULE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  buses        Bus[]
  stops        RouteStop[]
}

model Bus {
  id           String              @id @default(cuid())
  fleetCode    String              @unique
  rfidTag      String              @unique
  model        String
  capacity     Int
  status       BusOperationalStatus @default(ACTIVE)
  serviceStatus BusServiceStatus    @default(NORMAL)
  etaMinutes   Int?
  lastStop     String?
  passengers   Int                @default(0)
  heading      String             @default("Unknown")
  routeId      String?
  route        Route?              @relation(fields: [routeId], references: [id], onDelete: SetNull)
  state        BusState?
  events       BusEvent[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Stop {
  id        String      @id @default(cuid())
  name      String
  lat       Float
  lng       Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  routes    RouteStop[]
  events    BusEvent[]
  lastSeen  BusState[]  @relation("BusStateLastStop")
  nextStops BusState[]  @relation("BusStateDestination")
}

model RouteStop {
  id        String   @id @default(cuid())
  routeId   String
  stopId    String
  order     Int
  schedule  String   @default("00:00")
  createdAt DateTime @default(now())

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop  Stop  @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@index([routeId, order])
  @@unique([routeId, stopId])
}

model BusEvent {
  id        String       @id @default(cuid())
  busId     String
  type      BusEventType
  delta     Int?
  stopId    String?
  rfidTag   String?
  payload   Json?
  createdAt DateTime     @default(now())

  bus  Bus  @relation(fields: [busId], references: [id], onDelete: Cascade)
  stop Stop? @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([busId, createdAt])
}

model BusState {
  busId             String   @id
  passengers        Int      @default(0)
  lastStopId        String?
  destinationStopId String?
  updatedAt         DateTime @updatedAt

  bus         Bus   @relation(fields: [busId], references: [id], onDelete: Cascade)
  lastStop    Stop? @relation("BusStateLastStop", fields: [lastStopId], references: [id])
  destination Stop? @relation("BusStateDestination", fields: [destinationStopId], references: [id])
}
